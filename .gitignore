# Claude Code local logs (machine-specific session metadata)
.claude/logs/

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp

# Environment / secrets — real .env stays local; the .example template IS tracked
.env
.env.*
!.env.example
*.local

# Node / build artifacts (root-level only — anchored so docs/build/ is NOT ignored)
node_modules/
/dist/
/build/

# SvelteKit
/.svelte-kit
/package
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Rust / Tauri build artifacts
src-tauri/target/
spikes/target/
# Tauri auto-generated capability schemas
src-tauri/gen/schemas

# Python
__pycache__/
*.py[cod]
.venv/
venv/
